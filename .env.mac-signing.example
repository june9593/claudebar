# macOS code signing + notarization (electron-builder)
# Copy to .env (gitignored) or export in your shell before running:
#   npm run pack:mac:dmg:arm64

# Apple Developer Team ID (10 chars, e.g. ABCDE12345)
APPLE_TEAM_ID=

# Developer ID Application certificate identity in Keychain.
# Format must match exactly, e.g.:
#   "Developer ID Application: Your Name (ABCDE12345)"
CSC_NAME=

# Notarization via App Store Connect API key (recommended).
# Download AuthKey_XXXXXXXXXX.p8 from appstoreconnect.apple.com -> Users and Access -> Integrations.
APPLE_API_KEY=~/private_keys/AuthKey_XXXXXXXXXX.p8
APPLE_API_KEY_ID=
APPLE_API_ISSUER=

# --- Alternative: app-specific password (skip if using API key above) ---
# APPLE_ID=
# APPLE_APP_SPECIFIC_PASSWORD=
