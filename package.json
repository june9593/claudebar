{
  "name": "claudebar",
  "version": "0.7.2",
  "description": "Floating-window desktop app for local Claude Code CLI sessions (BYO-CLI)",
  "main": "dist-electron/electron/main.js",
  "homepage": "https://github.com/june9593/claudebar",
  "repository": {
    "type": "git",
    "url": "https://github.com/june9593/claudebar.git"
  },
  "bugs": {
    "url": "https://github.com/june9593/claudebar/issues"
  },
  "scripts": {
    "dev": "vite",
    "dev:electron": "npm run build:electron && electron .",
    "build": "vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.node.json",
    "preview": "vite preview",
    "pack:mac:dmg:arm64": "npm run build && electron-builder --mac dmg --arm64",
    "pack:mac:dmg:arm64:release": "npm run build && electron-builder --mac dmg --arm64 -c.mac.notarize=true && node scripts/notarize-dmg.mjs",
    "pack:mac:dmg:x64": "npm run build && electron-builder --mac dmg --x64",
    "pack:mac:dmg:x64:release": "npm run build && electron-builder --mac dmg --x64 -c.mac.notarize=true && node scripts/notarize-dmg.mjs",
    "pack:win": "npm run build && electron-builder --win --x64",
    "pack:win:nsis": "npm run build && electron-builder --win nsis --x64",
    "pack:win:portable": "npm run build && electron-builder --win portable --x64",
    "clean": "node -e \"const fs=require('fs');for(const d of ['dist','dist-electron','release-artifacts'])fs.rmSync(d,{recursive:true,force:true});\""
  },
  "keywords": [
    "claude-code",
    "claude",
    "anthropic",
    "menu-bar",
    "macos",
    "windows",
    "electron"
  ],
  "author": "june9593",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.0",
    "autoprefixer": "^10.4.20",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.7.0",
    "vite": "^6.2.0"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.121",
    "bonjour-service": "^1.3.0",
    "lucide-react": "^1.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "ws": "^8.20.1",
    "zustand": "^5.0.0"
  }
}
